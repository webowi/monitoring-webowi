{% extends "dashboard/authentication/base-authentication.html.twig" %}

{% block body %}
    <section class="auth">
        <div class="auth__bg" aria-hidden="true">
            <img
                    src="{{ asset('assets/dashboard-ui/authentication/assets/images/buildings.webp') }}"
                    alt=""
                    class="auth__bgImage"
                    loading="lazy"
                    decoding="async"
            />
        </div>

        <div class="auth__content">
            <div class="authCard" role="region" aria-label="Ustaw nowe hasło">
                <header class="authCard__header">
                    <h1 class="authCard__title">
                        {% trans %}dashboard.authentication.resetPassword.title{% endtrans %}
                    </h1>
                    <p class="authCard__subtitle">
                        Ustaw nowe hasło do konta.
                    </p>
                </header>

                {% if form_errors(resetPasswordForm) %}
                    <div class="alert alert--error" role="alert">
                        {{ form_errors(resetPasswordForm) }}
                    </div>
                {% endif %}

                {{ form_start(resetPasswordForm, { attr: { class: 'authForm', novalidate: 'novalidate' } }) }}
                <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}"/>

                <div class="authField">
                    {{ form_row(resetPasswordForm.password.first, {
                        row_attr: { class: 'authField__row' },
                        attr: {
                            class: 'authInput',
                            autocomplete: 'new-password'
                        }
                    }) }}
                </div>

                <div class="authField">
                    {{ form_row(resetPasswordForm.password.second, {
                        row_attr: { class: 'authField__row' },
                        attr: {
                            class: 'authInput',
                            autocomplete: 'new-password'
                        }
                    }) }}
                </div>

                <button class="btn btn--primary btn--block" type="submit">
                    {% trans %}dashboard.authentication.resetPassword.submit{% endtrans %}
                </button>
                {{ form_end(resetPasswordForm) }}

                <div class="authCard__footer authCard__footer--split">
                    <a href="{{ path('app_login') }}" class="authLink authLink--muted">
                        ← {% trans %}dashboard.authentication.login.submit{% endtrans %}
                    </a>
                </div>
            </div>
        </div>
    </section>
{% endblock %}