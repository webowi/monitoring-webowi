{% extends "dashboard/authentication/base-email-template.html.twig" %}

{% block content %}
    <tr>
        <td align="center" bgcolor="#f4f6f9" style="padding: 40px 20px;">
            <table align="center" border="0" cellpadding="0" cellspacing="0" width="100%" style="max-width:600px; background:#ffffff; border-radius:12px; overflow:hidden;">

                <!-- Header -->
                <tr>
                    <td align="center" style="padding:40px 30px 10px 30px; font-family: Arial, Helvetica, sans-serif;">
                        <h1 style="margin:0; font-size:24px; font-weight:700; color:#111827;">
                            {% trans %}dashboard.authentication.resetPassword.email.template.title{% endtrans %}
                        </h1>
                    </td>
                </tr>

                <!-- Description -->
                <tr>
                    <td align="center" style="padding:10px 30px 0 30px; font-family: Arial, Helvetica, sans-serif; font-size:15px; line-height:22px; color:#4b5563;">
                        {% trans %}dashboard.authentication.resetPassword.email.template.description{% endtrans %}
                    </td>
                </tr>

                <!-- Button -->
                <tr>
                    <td align="center" style="padding:30px;">
                        <table border="0" cellspacing="0" cellpadding="0">
                            <tr>
                                <td align="center" bgcolor="#8d1519" style="border-radius:8px;">
                                    <a href="{{ url('app_reset_password', {'token': token, 'emailValue': emailValue}) }}"
                                       target="_blank"
                                       style="display:inline-block; padding:14px 28px; font-family: Arial, Helvetica, sans-serif; font-size:15px; font-weight:600; color:#ffffff; text-decoration:none;">
                                        {% trans %}dashboard.authentication.resetPassword.email.template.submit{% endtrans %}
                                    </a>
                                </td>
                            </tr>
                        </table>
                    </td>
                </tr>

                <!-- Divider -->
                <tr>
                    <td style="padding:0 30px;">
                        <hr style="border:none; border-top:1px solid #e5e7eb;">
                    </td>
                </tr>

                <!-- Security note -->
                <tr>
                    <td align="center" style="padding:20px 30px 40px 30px; font-family: Arial, Helvetica, sans-serif; font-size:13px; line-height:20px; color:#6b7280;">
                        {% trans %}dashboard.authentication.resetPassword.email.template.securityInfo{% endtrans %}
                        <br><br>
                        Jeśli przycisk nie działa, skopiuj i wklej poniższy link do przeglądarki:
                        <br>
                        <a href="{{ url('app_reset_password', {'token': token, 'emailValue': emailValue}) }}"
                           style="color:#8d1519; word-break:break-all;">
                            {{ url('app_reset_password', {'token': token, 'emailValue': emailValue}) }}
                        </a>
                    </td>
                </tr>

            </table>
        </td>
    </tr>
{% endblock %}