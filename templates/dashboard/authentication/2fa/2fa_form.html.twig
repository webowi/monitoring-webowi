{% extends "dashboard/authentication/base-authentication.html.twig" %}

{% block title %}{% trans %}dashboard.account.2fa.title{% endtrans %}{% endblock %}

{% block body %}
    <section class="auth">
        <div class="auth__bg" aria-hidden="true">
            <img
                    src="{{ asset('assets/dashboard-ui/authentication/assets/images/background-monitoring.webp') }}"
                    alt=""
                    class="auth__bgImage"
                    loading="lazy"
                    decoding="async"
            />
        </div>

        <div class="auth__content">
            <div class="authCard" role="region" aria-label="{% trans %}dashboard.account.2fa.title{% endtrans %}">
                <header class="authCard__header">
                    <h1 class="authCard__title">{% trans %}dashboard.account.2fa.title{% endtrans %}</h1>
                    <p class="authCard__subtitle">{% trans %}dashboard.account.2fa.description{% endtrans %}</p>
                </header>

                <form
                        method="POST"
                        action="{{ checkPathUrl ? checkPathUrl : path(checkPathRoute) }}"
                        class="authForm"
                        novalidate
                        autocomplete="off"
                >
                    {% if authenticationError %}
                        <div class="alert alert--error" role="alert">
                            {{ authenticationError|trans(authenticationErrorData, 'SchebTwoFactorBundle') }}
                        </div>
                    {% endif %}

                    <div class="authField">
                        <label for="_auth_code" class="authLabel">
                            {% trans %}dashboard.account.2fa.code{% endtrans %}
                        </label>
                        <input
                                id="_auth_code"
                                type="text"
                                class="authInput authInput--mono"
                                name="{{ authCodeParameterName }}"
                                inputmode="numeric"
                                autocomplete="one-time-code"
                                placeholder="123 456"
                                required
                                autofocus
                        />
                        <div class="authHint">Wpisz kod z aplikacji uwierzytelniającej.</div>
                    </div>

                    {% if displayTrustedOption %}
                        <label class="authCheck">
                            <input id="_trusted" class="authCheck__input" type="checkbox" name="{{ trustedParameterName }}" />
                            <span class="authCheck__text">{{ "trusted"|trans({}, 'SchebTwoFactorBundle') }}</span>
                        </label>
                    {% endif %}

                    {% if isCsrfProtectionEnabled %}
                        <input type="hidden" name="{{ csrfParameterName }}" value="{{ csrf_token(csrfTokenId) }}">
                    {% endif %}

                    <div class="authActions">
                        <a href="{{ logoutPath }}" class="btn btn--ghost">
                            {{ "cancel"|trans({}, 'SchebTwoFactorBundle') }}
                        </a>
                        <button type="submit" class="btn btn--primary">
                            {% trans %}dashboard.authentication.login.submit{% endtrans %}
                        </button>
                    </div>
                </form>

                <div class="authCard__footer authCard__footer--center">
                    <span class="authFooterText">© 2026 — Webowi.pl</span>
                </div>
            </div>
        </div>
    </section>
{% endblock %}